# FastAPI agent backend (SSE streaming, LangChain agent with provider cascade).
FROM python:3.12-slim
WORKDIR /app
COPY backend/requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt
COPY backend/ ./backend/
COPY www/ ./www/
ENV WWW_DIR=/app/www
RUN useradd --system --no-create-home portfolio
USER portfolio
WORKDIR /app/backend
EXPOSE 8001
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8001", "--workers", "1"]
