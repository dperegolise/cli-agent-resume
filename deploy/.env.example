# ── Model cascade API keys ──────────────────────────────────────────────────

# OpenRouter (first-priority provider; free-tier models available)
# Get a key at https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-...

# Comma-separated list of model IDs to try in order.
# Free-tier examples:
OPENROUTER_MODELS=mistralai/mistral-7b-instruct:free,meta-llama/llama-3-8b-instruct:free

# HuggingFace Inference API (second-priority provider)
# Get a key at https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_...

# Comma-separated list of HuggingFace model IDs to try in order.
HF_MODELS=mistralai/Mistral-7B-Instruct-v0.2

# ── routr (optional completions proxy, fallback provider) ───────────────────
# URL of a running routr instance. If unavailable, the cascade skips it.
ROUTR_URL=http://127.0.0.1:8000

# ── Rate limiting ───────────────────────────────────────────────────────────
# Max agent requests per IP per 60-second sliding window before ban.
AGENT_RATE_LIMIT=20

# How long (hours) a banned IP remains banned.
AGENT_BAN_DURATION_HOURS=24
